<Card@BoxLayout>
    orientation: "vertical"
    padding: 10
    spacing: 5
    canvas.before:
        Color:
            rgba: .15,.15,.15,1

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [15]

<DashboardScreen>
    BoxLayout:
        orientation:"vertical"

        ScrollView:
    
            BoxLayout:
                orientation: "vertical"
                size_hint_y: None
                height: self.minimum_height
                spacing: 15
                padding: [15, 22, 15, 15]
    
                BoxLayout:
					orientation: "horizontal"
					spacing: 8
					size_hint_y: None
					height: 40

					Label:
						font_name: "MaterialIcons"
						text: app.icons.BALANCE
						font_size: "24sp"
						size_hint_x: None
						width: 40

					Label:
						text: "Finance Manager"
						bold: True
    
                # BALANCE CARD
                Card:
                    size_hint_y: None
                    height: app.metrics.Size.BALANCE_CARD_HEIGHT
      
                    BoxLayout:
						orientation: "horizontal"
						spacing: dp(4)
						size_hint_y: None
						height: dp(28)

						Label:
							font_name: "MaterialIcons"
							text: app.icons.BALANCE
							font_size: "18sp"
							size_hint_x: None
							width: dp(30)

						Label:
							text: "Balance"
							font_size: app.metrics.Font.CARD_TITLE
      
                    Label:
                        text: f"-₹{abs(app.balance):,.0f}" if app.balance < 0 else f"₹{app.balance:,.0f}"
                        bold: True
                        font_size: app.metrics.Font.CARD_VALUE
                
    
                # INCOME + EXPENSE CARDS
                BoxLayout:
                    size_hint_y: None
                    height: app.metrics.Size.STAT_CARD_HEIGHT
                    spacing: 10
    
                    Card:
                        canvas.before:
                            Color:
                                rgba: 0,.4,0,1
        
                                RoundedRectangle:
                                    pos:self.pos
                                    size:self.size
                                    radius:[15]
    
                        BoxLayout:
							orientation: "horizontal"
							spacing: dp(4)
							size_hint_y: None
							height: dp(28)

							Label:
								font_name: "MaterialIcons"
								text: app.icons.INCOME
								font_size: "18sp"
								size_hint_x: None
								width: dp(30)

							Label:
								text: "Income"
								font_size: app.metrics.Font.CARD_TITLE
                        
                        Label:
                            text: f"₹{app.income:,.0f}"
							color: 0,1,0,1
                            font_size: app.metrics.Font.CARD_VALUE
					
					# expense card
                    Card:
                        canvas.before:
                            Color:
                                rgba:.15,.15,.15,1
              
                            RoundedRectangle:
                                pos:self.pos
                                size:self.size
                                radius:[15]
                
                        BoxLayout:
							orientation: "horizontal"
							spacing: dp(4)
							size_hint_y: None
							height: dp(28)

							Label:
								font_name: "MaterialIcons"
								text: app.icons.EXPENSE
								font_size: "18sp"
								size_hint_x: None
								width: dp(30)

							Label:
								text: "Expense"
								font_size: app.metrics.Font.CARD_TITLE
                
                        Label:
                            text: f"₹{app.expense:,.0f}"
							color: 1,.35,.35,1
                            font_size: app.metrics.Font.CARD_VALUE
    
                # TOP CATEGORY CARD and This Month
                BoxLayout:
                    size_hint_y: None
                    height: app.metrics.Size.STAT_CARD_HEIGHT
                    spacing: 10
                    
                    Card:
                        BoxLayout:
							orientation: "horizontal"
							spacing: dp(4)
							size_hint_y: None
							height: dp(28)

							Label:
								font_name: "MaterialIcons"
								text: app.icons.CATEGORY
								font_size: "18sp"
								size_hint_x: None
								width: dp(30)

							Label:
								text: "Top Category"
								font_size: app.metrics.Font.CARD_TITLE
                
                        Label:
                            text: app.top_category_text
                
                    Card:
                        BoxLayout:
							orientation: "horizontal"
							spacing: dp(8)
							size_hint_y: None
							height: dp(28)

							Label:
								font_name: "MaterialIcons"
								text: app.icons.CALENDAR
								font_size: "18sp"
								size_hint_x: None
								width: dp(30)

							Label:
								text: "This Month"
								font_size: app.metrics.Font.CARD_TITLE
                        Label:
                            text: app.monthly_expense_text
				
				
            
    
                # -------------------------
				# Recent Transactions
				# -------------------------

				BoxLayout:
					size_hint_y: None
					height: 36

					Label:
						text: "Recent Transactions"
						bold: True
						font_size: app.metrics.Font.CARD_TITLE
						halign: "left"
						text_size: self.size

					Button:
						text: "View All"
						size_hint_x: None
						width: dp(90)
						background_normal: ""
						background_color: 0,0,0,0

						on_press:
							app.go_to_screen("history")
				
				# adding top margin
				Widget:
					size_hint_y: None
					height: dp(6)
				
				# recent transaction box
				BoxLayout:
					id: recent_box

					orientation: "vertical"

					spacing: dp(8)

					size_hint_y: None

					height: self.minimum_height
    
                
        BottomNav:
            
          

<TransactionRow>:

    size_hint_y: None
    height: 90
    spacing: 5

    canvas.before:
        Color:
            rgba: .12, .12, .12, 1
    
        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    canvas.after:
        Color:
            rgba: .3, .3, .3, 1

        Line:
            points: [self.x, self.y, self.right, self.y]

            width: 1

    BoxLayout:
        orientation: "vertical" #left side
        size_hint_x: .65
        padding: [10,6]

        Label:
            text: root.category
            bold: True
            halign: "left"
            text_size: self.size
			height: 32

        Label:
            text: root.date
            #font_size: 26
            color: .7,.7,.7,1
            halign: "left"
            text_size: self.size
			size_hint_y: None
			height: 24

    Label:
        text: root.amount
        size_hint_x: .15
        bold: True
        color: root.amount_color

    BoxLayout:
        orientation: "vertical"
        size_hint_x: .12
        

        Button:
            text: "E"

            on_press:
                app.open_edit(root.transaction_id)

        Button:
            text: "X"

            on_press:
                app.delete_transaction(root.transaction_id)

<DashboardTransactionRow@BoxLayout>

    size_hint_y: None
    height: dp(78)

    orientation: "vertical"

    padding: [12,8]

    spacing: 2

    canvas.before:
        Color:
            rgba: .12,.12,.12,1

        RoundedRectangle:
            pos: self.pos
            size: self.size
            radius: [10]

    BoxLayout:
        size_hint_y: None
        height: dp(24)

        Label:
            text: root.category
            bold: True
            halign: "left"
            valign: "middle"
            text_size: self.size

        Label:
            text: root.amount
            bold: True
            halign: "right"
            valign: "middle"
            text_size: self.size
            color: root.amount_color

    Label:
        text: root.note
        size_hint_y: None
        height: dp(18)

        halign: "left"
        valign: "middle"

        text_size: self.size

        color: .75,.75,.75,1

    Label:
        text: root.date

        size_hint_y: None
        height: dp(16)

        halign: "left"
        valign: "middle"

        text_size: self.size

        color: .55,.55,.55,1
            

<AddTransactionScreen>:

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Label:
            text: "ADD TRANSACTION"
            font_size: 24
            bold: True
            size_hint_y: None
            height: 40

        # Balance Card
        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: 140
            padding: 10

            canvas.before:
                Color:
                    rgba: .15,.15,.15,1

                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]

            Label:
                text: "Current Balance"
                size_hint_y: .3
                bold: True
                font_size: 36

            Label:
                text: f"₹{app.balance}"
                size_hint_y: .5
                font_size: 28
                halign: "center"
                valign: "middle"
                text_size: self.size
                bold: True
                color: (1,0.3,0.3,1) if app.balance < 0 else (0,1,0,1)

            Label:
                markup: True
                text: f"[color=00ff00]₹{app.total_income:.0f}[/color] [color=ff5555]₹{app.total_expense:.0f}[/color]"
                size_hint_y: .3
                font_size: 24
                color: .8,.8,.8,1

        TextInput:
            id: amount
            hint_text: "₹ Amount"
            multiline: False
            input_filter: "float"
            font_size: 28
            size_hint_y: None
            height: 60
            halign: "center"

        Spinner:
            id: category
            text: "Food"
            values: app.categories
            size_hint_y: None
            height: 55
            font_size: 24

        TextInput:
            id: note
            hint_text: "Note (optional)"
            size_hint_y: None
            height: 80

        # Recent Transactions Card
        BoxLayout:
            orientation: "vertical"
            size_hint_y: None
            height: 260
            padding: 10

            canvas.before:
                Color:
                    rgba: .15,.15,.15,1

                RoundedRectangle:
                    pos: self.pos
                    size: self.size
                    radius: [15]

            Label:
                text: "Recent Transactions"
                size_hint_y: None
                height: 30
                bold: True

            ScrollView:
                GridLayout:
                    id: recent_list
                    cols: 1
                    spacing: 5
                    size_hint_y: None
                    height: self.minimum_height

        # Income / Expense Buttons
        BoxLayout:
            size_hint_y: None
            height: 55
            spacing: 10

            Button:
                text: "+ Income"
                background_color: 0, 0.6, 0, 1

                on_press:
                    app.add_transaction(
                    amount.text,
                    category.text,
                    note.text,
                    "Income")

            Button:
                text: "- Expense"
                background_color: 0.7, 0, 0, 1

                on_press:
                    app.add_transaction(
                    amount.text,
                    category.text,
                    note.text,
                    "Expense")

        Widget:

        BottomNav:
        


<HistoryScreen>

    BoxLayout:
        orientation: "vertical"
        
        Label:
            text: "HISTORY"
            font_size: 28
            bold: True
            size_hint_y: None
            height: 60
        
        # search box
        BoxLayout:
            size_hint_y:None
            height:60
            
            Widget:
                size_hint_x:.2
            
            TextInput:
                hint_text: "Search transaction..."
                multiline: False
                    
                background_normal: ""
                background_active: ""
            
                #background_color: 0,0,0,0
                #foreground_color: 0,0,0,1
                #cursor_color: 0,0,0,1
            
                padding: [20,10]
            
                size_hint: 1,1
            
                on_text:
                    app.update_search(self.text)
            Widget:
                size_hint_x:.2

        # spacer
        BoxLayout:
            size_hint_y: None
            height: 20

        Spinner:
            text: "All"
            values: ("All", "Income", "Expense")
            size_hint_y: None
            height: 45

            on_text:
                app.update_filter(self.text)
        
        Spinner:
            text: "Newest First"
            values:("Newest First","Oldest First","Highest Amount","Lowest Amount")
            size_hint_y: None
            height: 45

            on_text:
                app.update_sort(self.text)
        
        RecycleView:
            viewclass: "TransactionRow"
            
            data: app.transaction_data
            
            RecycleBoxLayout:
                default_size: None, 90
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: "vertical"
                spacing: 2

        
        
        BottomNav:

<ReportScreen>

    BoxLayout:
        orientation: "vertical"
        
        Label:
            text: app.expense_summary()
            
        Label:
            text: app.category_report()

        
        
        BottomNav:

# under view history                
<EditTransactionScreen>

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        TextInput:
            id: amount
            hint_text: "Amount"

        TextInput:
            id: category
            hint_text: "Category"
        
        TextInput:
            id: note
            hint_text: "note"
        
        TextInput:
            id: date
            hint_text: "Date"
        
        Button:
            text: "Change Date"

            on_press:
                app.edit_date_popup()
        

        Button:
            text: "Save"

            on_press:
                app.save_edit(
                amount.text,
                category.text,
                note.text,
                date.text
                )

        Button:
            text: "Cancel"

            on_press:
                app.go_to_screen("history")
                
<StatisticsScreen>:

    BoxLayout:
        orientation: "vertical"

        ScrollView:

            Label:
                text: app.category_statistics()

                text_size: self.width, None

                size_hint_y: None

                height: self.texture_size[1]

        
        
        BottomNav:

<DataManagementScreen>:

    BoxLayout:
        orientation: "vertical"

        ScrollView:

            Label:
                text: " Data Management"

                text_size: self.width, None

                size_hint_y: None

                height: self.texture_size[1]
        
        Label:
            text:"Current Database:" + app.current_database
            
            size_hint_y: None
            height:80
            
        Label:
            text:"Available Databases"
        
            size_hint_y:None
            height:40
        
        RecycleView:
            viewclass: "DatabaseRow"
            data: app.database_data
        
            RecycleBoxLayout:
                default_size: None,50
                default_size_hint:1,None
            
                size_hint_y:None 
                height:self.minimum_height
                orientation:"vertical"
        
        Button:
            text: "Create New Database"
            on_press:app.create_database_popup()        
        
                
        Button:
            text: "Backup Data"

            size_hint_y: .15

            on_press:
                app.backup_data()
        
        Button:
            text: "Import Database"
            size_hint_y: .15
            on_press: app.show_import_popup()
        
        Button:
            text: "clear Data"

            size_hint_y: .15

            on_press:
                app.clear_all_data()
        
        Button:
            text: "Export CSV"
            size_hint_y: None
            #height: 60
            on_press: app.export_csv()
                
        
        BottomNav:


<RecurringScreen>

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        TextInput:
            id: amount
            hint_text: "Amount"

        Spinner:
            id: category
            text: "Food"

            values: app.categories

        TextInput:
            id: day
            hint_text: "Day Of Month"

        Label:
            text: "Example: 24 = 24th of every month"
            size_hint_y: None
            height: 30

        Button:
            text: "Add Recurring Expense"

            on_press:
                app.add_recurring(amount.text,category.text,day.text)
        
        BottomNav:

<DatabaseRow@BoxLayout>
    db_name: ""
    Label:
        text: root.db_name
    Button:
        text: "Open"
        size_hint_x: .25
        on_press:app.switch_database(root.db_name)
    Button:
        text:"Rename"
        size_hint_x:.25
        on_press:
            app.rename_database_popup(root.db_name)
    
    Button:
        text: "Delete"
        size_hint_x: .25
        on_press:
            app.delete_database_popup(root.db_name)

<ManageTransactionsScreen>

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        Button:
            text: "Add Recurring Transaction"

            on_press:
                app.go_to_screen("recurring")

        Button:
            text: "Manage Recurring Transactions"

            on_press:
                app.open_manage_recurring()
        
        Button:
            text: "Manage Categories"

            on_press:
                app.go_to_screen("categories")

        
        
        BottomNav:
       
# this screen shows all reccuring transaction and delete edit function       
<RecurringRow>

    size_hint_y: None
    height: 100

    Label:
        text: root.text
    
    Button:
        text: "Edit"
        size_hint_x: .3
        on_press:app.edit_recurring(root.index)

    Button:
        text: "Delete"
        size_hint_x: .3
        on_press:app.delete_recurring(root.index)

# dashboard->manage transaction-> manage recuring screen
<ManageRecurringScreen>

    BoxLayout:
        orientation: "vertical"

        RecycleView:

            viewclass: "RecurringRow"

            data:
                app.recurring_data

            RecycleBoxLayout:
                default_size: None, 100
                default_size_hint: 1, None
                size_hint_y: None
                height: self.minimum_height
                orientation: "vertical"

        
        
        BottomNav:

<CategoryScreen>

    BoxLayout:
        orientation: "vertical"
        padding: 10
        spacing: 10

        TextInput:
            id: category_name
            hint_text: "New Category"

        Button:
            text: "Add Category"

            on_press:
                app.add_category(category_name.text)

        RecycleView:

            viewclass: "CategoryRow"

            data: app.category_data

            RecycleBoxLayout:

                default_size: None, 60
                default_size_hint: 1, None

                size_hint_y: None

                height: self.minimum_height

                orientation: "vertical"
               
        
        
        BottomNav:

<CategoryRow>

    Label:
        text: root.text

    Button:
        text: "Edit"

        size_hint_x: .2

        on_press:
            app.edit_category(root.category_id,root.text)

    Button:
        text: "Delete"

        size_hint_x: .2

        on_press:
            app.delete_category(root.category_id)


<BottomNav@BoxLayout>

    size_hint_y: None
    height: app.metrics.Size.BOTTOM_NAV_HEIGHT

    Button:
        markup: True
        text: f"[font=MaterialIcons]{app.icons.HOME}[/font]\nHome"
        font_size: app.metrics.Font.NAVIGATION
        background_color: (0.2,0.5,1,1) if app.current_screen in ["dashboard","statistics","datamanagement","manage_transactions","manage_recurring","categories"] else (0.3,0.3,0.3,1)
        on_press: app.go_to_screen("dashboard")

    Button:
        markup: True
        text: f"[font=MaterialIcons]{app.icons.ADD}[/font]\nAdd"
        font_size: app.metrics.Font.NAVIGATION
        background_color: (0.2,0.5,1,1) if app.current_screen == "add" else (0.3,0.3,0.3,1)
        on_press: app.go_to_screen("add")

    Button:
        markup: True
        text: f"[font=MaterialIcons]{app.icons.HISTORY}[/font]\nHistory"
        font_size: app.metrics.Font.NAVIGATION
        background_color: (0.2,0.5,1,1) if app.current_screen == "history" else (0.3,0.3,0.3,1)
        on_press: app.go_to_screen("history")

    Button:
        markup: True
        text: f"[font=MaterialIcons]{app.icons.REPEAT}[/font]\nRepeat"
        font_size: app.metrics.Font.NAVIGATION
        background_color: (0.2,0.5,1,1) if app.current_screen == "recurring" else (0.3,0.3,0.3,1)
        on_press: app.go_to_screen("recurring")

    Button:
        markup: True
        text: f"[font=MaterialIcons]{app.icons.MORE}[/font]\nMore"
        font_size: app.metrics.Font.NAVIGATION
        background_color: (0.3,0.3,0.3,1)
        on_press: app.more_menu()

